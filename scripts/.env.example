# Copy this file to .env and fill in your values

# MongoDB connection string
MONGO_URL=your_mongodb_connection_string

# LeetCode scraping (for scrape.py)
LEETCODE_CSRF_TOKEN=your_csrf_token_from_browser

# Gemini API keys (comma-separated, for gemini_process.py)
GEMINI_API_KEYS=key1,key2,key3

# OpenAI (for openai_process.py, openai_batch.py, openai_4omini.py)
OPENAI_API_KEY=your_openai_key

# DeepSeek (for deepseek_process.py)
DEEPSEEK_API_KEY=your_deepseek_key
